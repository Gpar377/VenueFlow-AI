# ╔══════════════════════════════════════════════════════════════╗
# ║  VenueFlow AI — Environment Configuration                   ║
# ║  Copy this file to .env and add your API keys               ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── REQUIRED ────────────────────────────────────────────────
# Get your FREE API key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ─── OPTIONAL: Google Maps ───────────────────────────────────
# Enables real Google Maps overlay on venue map
# Get key at: https://console.cloud.google.com/apis
GOOGLE_MAPS_API_KEY=

# ─── OPTIONAL: Firebase ─────────────────────────────────────
# Enables real-time multi-device sync
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_DATABASE_URL=

# ─── AI MODEL CONFIG ────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1024

# ─── SERVER CONFIG ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ─── SIMULATION CONFIG ──────────────────────────────────────
VENUE_CAPACITY=50000
SIMULATION_TICK_SECONDS=5
MAX_QUEUE_WAIT_MINUTES=45
